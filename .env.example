# CloudGuard WAF MCP Server Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control

# Required: GraphQL API endpoint URL
WAF_ENDPOINT_URL=https://cloudinfra-gw-us.portal.checkpoint.com/app/waf/graphql/v1

# Required: Client ID for authentication
WAF_CLIENT_ID=your-client-id-here

# Required: Secret key for authentication (keep this secret!)
WAF_SECRET_KEY=your-secret-key-here

# Optional: Authentication endpoint URL (if different from default)
WAF_AUTH_URL=https://cloudinfra-gw-us.portal.checkpoint.com/auth/external

# Optional: Pre-generated auth token (if not provided, token will be auto-generated)
WAF_AUTH_TOKEN=
